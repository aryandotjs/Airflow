// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String

  zaps         Zap[]
  caredentials Credential[]
}

model Credential {
  id        String          @id @default(uuid())
  name      String
  value     String
  type      CredentialsType
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user   User? @relation(fields: [userId], references: [id])
  userId Int?
}

enum CredentialsType {
  CLAUDE
  GEMINI
  CHATGPT
}

enum ZapStatus {
  ACTIVE
  PAUSED
  DRAFT
}

// dont for get to remove this defoult now in update at 
// dont for get to add a last used table 
model Zap {
  id        String    @id @default(uuid())
  name      String    @default("unnamed-workflow")
  runs      Int       @default(0)
  status    ZapStatus @default(DRAFT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  trigger   Trigger?
  actions   Action[]
  zapRuns   Zaprun[]
}

model Trigger {
  id        String           @id @default(uuid())
  triggerId String
  zapId     String           @unique
  metadata  Json             @default("{}")
  type      AvailableTrigger @relation(fields: [triggerId], references: [id])
  Zap       Zap              @relation(fields: [zapId], references: [id], onDelete: Cascade)
}

model AvailableTrigger {
  id    String @id @default(uuid())
  name  String @unique
  image String

  triggers Trigger[]
}

model Action {
  id           String          @id @default(uuid())
  metadata     Json            @default("{}")
  sortingOrder Int             @default(0)
  zapId        String
  Zap          Zap             @relation(fields: [zapId], references: [id], onDelete: Cascade)
  ActionId     String
  type         AvailableAction @relation(fields: [ActionId], references: [id])
}

model AvailableAction {
  id    String @id @default(uuid())
  name  String @unique
  image String

  actions Action[]
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model Zaprun {
  id            String          @id @default(uuid())
  name          String          @default("undefined-execution-name")
  startDate     DateTime        @default(now())
  completedDate DateTime        @default(now())
  duration      Int             @default(0)
  status        ExecutionStatus @default(SUCCESS)
  metadata      Json
  zapId         String
  type          Zap             @relation(fields: [zapId], references: [id], onDelete: Cascade)
  zapRunOutBox  zapRunOutBox?
}

model zapRunOutBox {
  id       String @id @default(uuid())
  zaprunId String @unique
  type     Zaprun @relation(fields: [zaprunId], references: [id])
}
